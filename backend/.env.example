# NeuroTrade AI — Backend Environment Variables
# Copy to .env and fill in your values

# OpenRouter API Key (required) — https://openrouter.ai/keys
OPENROUTER_API_KEY=key
# OpenRouter model — free tier default
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Apify API Token (required for live scraping) — https://apify.com/
APIFY_API_TOKEN=key

# Kalshi API Token (optional — public markets work without it)
KALSHI_API_TOKEN=
